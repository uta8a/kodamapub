{
  "name": "kodamapub-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "rm -rf dist .output && tsc -b && vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "serve": "node .output/server/index.js",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.server.json --noEmit",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "hono": "^4.9.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "oxfmt": "^0.48.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
